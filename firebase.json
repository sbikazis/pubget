{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "hosting": {
    "public": "preview",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/group/**",
        "destination": "/index.html"
      },
      {
        "source": "/g/**",
        "destination": "/index.html"
      },
      {
        "source": "/pricing",
        "destination": "/pages/pricing.html"
      },
      {
        "source": "/terms",
        "destination": "/pages/terms.html"
      },
      {
        "source": "/privacy",
        "destination": "/pages/privacy.html"
      },
      {
        "source": "/refund",
        "destination": "/pages/refund.html"
      }
    ],
    "headers": [
      {
        "source": "/pages/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  }
}
