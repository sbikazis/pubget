{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "hosting": {
    "public": "preview",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/group/**",
        "destination": "/index.html"
      },
      {
        "source": "/g/**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/pricing",
        "headers": [{"key": "Cache-Control", "value": "no-cache"}]
      },
      {
        "source": "/terms",
        "headers": [{"key": "Cache-Control", "value": "no-cache"}]
      },
      {
        "source": "/privacy",
        "headers": [{"key": "Cache-Control", "value": "no-cache"}]
      },
      {
        "source": "/refund",
        "headers": [{"key": "Cache-Control", "value": "no-cache"}]
      }
    ]
  }
}
